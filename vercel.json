{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix \"project 2\" install",
  "buildCommand": "npm --prefix \"project 2\" run build",
  "outputDirectory": "project 2/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
